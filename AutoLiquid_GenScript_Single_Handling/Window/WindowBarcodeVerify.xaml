<metro:MetroWindow
    x:Class="AutoLiquid_GenScript_Single_Handling.Window.WindowBarcodeVerify"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
    Title="{DynamicResource BarcodeVerifyTitle}"
    Width="700" Height="520"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowIconOnTitleBar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题提示 -->
        <TextBlock Grid.Row="0"
                   Text="{DynamicResource BarcodeVerifyHint}"
                   FontSize="14" FontWeight="Bold"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"/>

        <!-- 当前轮次信息 -->
        <TextBlock Grid.Row="1"
                   x:Name="TextBlockRoundInfo"
                   FontSize="12" Foreground="Gray"
                   Margin="0,0,0,8"/>

        <!-- 盘位网格 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="GridPlateLayout" Margin="4"/>
        </ScrollViewer>

        <!-- 状态提示 -->
        <TextBlock Grid.Row="3"
                   x:Name="TextBlockStatus"
                   FontSize="12" Margin="0,8,0,4"
                   Foreground="DimGray"
                   TextWrapping="Wrap"/>

        <!-- 底部按钮 -->
        <DockPanel Grid.Row="4" LastChildFill="False" Margin="0,4,0,0">
            <Button x:Name="BtnConfirm"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                    DockPanel.Dock="Right"
                    Content="{DynamicResource BarcodeVerifyConfirm}"
                    Width="90" Height="30" Margin="8,0,0,0"
                    IsEnabled="False"/>
            <Button x:Name="BtnCancel"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                    DockPanel.Dock="Right"
                    Content="{DynamicResource Cancel}"
                    Width="90" Height="30"/>
        </DockPanel>
    </Grid>
</metro:MetroWindow>