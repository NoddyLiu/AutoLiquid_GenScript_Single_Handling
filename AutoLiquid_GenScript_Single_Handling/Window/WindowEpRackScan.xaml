<metro:MetroWindow
    x:Class="AutoLiquid_GenScript_Single_Handling.Window.WindowEpRackScan"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
    Title="{DynamicResource EpRackScanTitle}"
    Width="640" Height="540"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowIconOnTitleBar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题提示 -->
        <TextBlock Grid.Row="0"
                   x:Name="TextBlockTitle"
                   FontSize="14" FontWeight="Bold"
                   Margin="0,0,0,6"
                   TextWrapping="Wrap"/>

        <!-- 进度 -->
        <TextBlock Grid.Row="1"
                   x:Name="TextBlockProgress"
                   FontSize="12" Foreground="Gray"
                   Margin="0,0,0,6"/>

        <!-- EP管架孔位网格（代码动态生成） -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <Grid x:Name="GridEpRack" Margin="4"/>
        </ScrollViewer>

        <!-- 状态提示 -->
        <TextBlock Grid.Row="3"
                   x:Name="TextBlockStatus"
                   FontSize="12" Margin="0,8,0,4"
                   Foreground="DimGray"
                   TextWrapping="Wrap"/>

        <!-- 取消按钮 -->
        <DockPanel Grid.Row="4" LastChildFill="False" Margin="0,4,0,0">
            <Button x:Name="BtnCancel"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                    DockPanel.Dock="Right"
                    Content="{DynamicResource Cancel}"
                    Width="90" Height="30"/>
        </DockPanel>
    </Grid>
</metro:MetroWindow>