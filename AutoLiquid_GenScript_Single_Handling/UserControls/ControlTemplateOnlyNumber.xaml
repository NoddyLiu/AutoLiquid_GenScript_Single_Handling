<UserControl x:Class="AutoLiquid_GenScript_Single_Handling.UserControls.ControlTemplateOnlyNumber"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_GenScript_Single_Handling.UserControls"
             mc:Ignorable="d" >
    <Grid>
        <Border BorderBrush="{StaticResource TemplateBorderColor}" BorderThickness="{StaticResource TemplateBorderThickness}">
            <TextBlock x:Name="TextBlockTemplateName" Text="{StaticResource Template}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource DefaultFontSize}"/>
        </Border>
    </Grid>
</UserControl>
